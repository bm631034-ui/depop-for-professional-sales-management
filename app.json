{
  "expo": {
    "name": "Depop Sales Manager",
    "slug": "depop-sales-manager",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.depopsalesmanager.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera access is needed to capture screenshots and images",
        "NSPhotoLibraryUsageDescription": "Photo library access is needed to upload images",
        "NSPhotoLibraryAddUsageDescription": "Permission to save photos to your library"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.depopsalesmanager.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your friends.",
          "cameraPermission": "The app uses the camera to capture photos"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "depop-sales-manager"
      }
    }
  }
}
